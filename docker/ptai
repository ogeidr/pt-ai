#!/bin/sh
# ptai: host wrapper for the pt-ai ephemeral Ubuntu container.
#
# Subcommands:
#   build                          Build the image (always with --pull).
#   auth                           One-time browser OAuth login; persists credential to host.
#   run <engagement-id> [opts]     Launch an ephemeral container for an engagement.
#                                    --shell           drop to bash instead of claude
#                                    --listen <port>   publish a host port for callbacks
#                                    -- <args>         extra args passed to claude
#
# Auth resolution at run time (in order):
#   1. ANTHROPIC_API_KEY in the host env -> passed through.
#   2. ~/.claude-pt-ai/.credentials.json -> mounted read-only.
#   3. neither -> fail with a hint.
#
# Environment overrides:
#   UBUNTU_TAG        base image tag (default: 24.04)
#   MCP_BRIDGE_REF    git ref of upstream MCP bridge to vendor (default: main;
#                     pin to a specific SHA for reproducibility)
#   PT_AI_IMAGE       image name (default: pt-ai:latest)
#   PT_AI_AUTH_DIR    host dir for OAuth credential (default: ~/.claude-pt-ai)
#   PT_AI_MCP_SERVER  REQUIRED at run time: URL of the remote MCP API server
#                     (e.g. http://host.docker.internal:5000 forwarded via SSH).
#
set -eu

# --- locate ourselves (POSIX, no GNU readlink) ----------------------------
SCRIPT="$0"
case "$SCRIPT" in
    /*) ;;
    *)  SCRIPT="$PWD/$SCRIPT" ;;
esac
DOCKER_DIR=$(cd "$(dirname "$SCRIPT")" && pwd)
REPO_DIR=$(cd "$DOCKER_DIR/.." && pwd)

IMAGE="${PT_AI_IMAGE:-pt-ai:latest}"
UBUNTU_TAG="${UBUNTU_TAG:-24.04}"
MCP_BRIDGE_REF="${MCP_BRIDGE_REF:-main}"
HOST_AUTH_DIR="${PT_AI_AUTH_DIR:-$HOME/.claude-pt-ai}"
# Claude Code stores some state at ~/.claude.json (a file alongside ~/.claude/).
# We persist a pt-ai-specific copy here and bind-mount it at runtime so the
# container appears as the same Claude Code install across runs.
HOST_AUTH_FILE="${PT_AI_AUTH_FILE:-$HOME/.claude-pt-ai-home.json}"

usage() {
    cat <<EOF
Usage: ptai <command> [options]

Commands:
  build                          Build the pt-ai image (uses UBUNTU_TAG, default 24.04)
  auth                           One-time browser OAuth login; persists credential to host
  run <engagement-id> [opts]     Launch ephemeral container for an engagement
                                   --shell           drop to bash instead of claude
                                   --listen <port>   publish a host port for callbacks
                                   -- <args>         extra args passed to claude

Environment:
  ANTHROPIC_API_KEY    if set, used directly (skips OAuth credential)
  UBUNTU_TAG           override base tag (default: 24.04)
  MCP_BRIDGE_REF       upstream git ref to vendor for the MCP bridge (default: main)
  PT_AI_IMAGE          override image name (default: pt-ai:latest)
  PT_AI_AUTH_DIR       host dir for OAuth credentials (default: ~/.claude-pt-ai)
  PT_AI_MCP_SERVER     REQUIRED at run time: URL of the remote MCP API server
                       (e.g. http://host.docker.internal:5000 forwarded via SSH)
EOF
}

cmd_build() {
    no_cache=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --no-cache) no_cache="--no-cache" ;;
            -h|--help)
                echo "Usage: ptai build [--no-cache]"
                return 0
                ;;
            *)
                echo "ptai build: unknown option: $1" >&2
                exit 1
                ;;
        esac
        shift
    done
    # shellcheck disable=SC2086
    docker build --pull $no_cache \
        --build-arg "UBUNTU_TAG=${UBUNTU_TAG}" \
        --build-arg "MCP_BRIDGE_REF=${MCP_BRIDGE_REF}" \
        -t "$IMAGE" \
        "$DOCKER_DIR"
}

cmd_auth() {
    mkdir -p "$HOST_AUTH_DIR"
    chmod 700 "$HOST_AUTH_DIR"
    [ -f "$HOST_AUTH_FILE" ] || printf '{}' > "$HOST_AUTH_FILE"
    chmod 600 "$HOST_AUTH_FILE"
    cat <<EOF
Launching the pt-ai container in auth mode.

Inside the container:
  1. Run:   claude /login     (or just 'claude' on first launch)
  2. Open the URL it prints in your host browser.
  3. Paste the resulting code back into the container prompt.
  4. Type 'exit' once login completes.

Your credential will persist at:
  $HOST_AUTH_DIR/.credentials.json
  $HOST_AUTH_FILE
EOF
    docker run --rm -it \
        --init \
        --name "pt-ai-auth-$(date +%s)" \
        -v "$HOST_AUTH_DIR:/home/operator/.claude" \
        -v "$HOST_AUTH_FILE:/home/operator/.claude.json" \
        --entrypoint /bin/bash \
        "$IMAGE" \
        -lc 'claude /login || claude; exec bash'
}

cmd_run() {
    if [ "$#" -lt 1 ]; then
        echo "ptai run: missing <engagement-id>" >&2
        usage
        exit 1
    fi
    eng_id="$1"; shift

    shell_mode=0
    listen_port=""
    extra_args=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --shell)  shell_mode=1 ;;
            --listen)
                shift
                if [ "$#" -lt 1 ]; then
                    echo "ptai run: --listen requires a port" >&2
                    exit 1
                fi
                listen_port="$1"
                ;;
            --)
                shift
                extra_args="$*"
                break
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "ptai run: unknown option: $1" >&2
                exit 1
                ;;
        esac
        shift
    done

    eng_dir="$REPO_DIR/engagements/$eng_id"
    mkdir -p "$eng_dir"

    # Auth: API key wins if both are present.
    # OAuth path mounts the whole ~/.claude-pt-ai dir writable so token
    # refreshes persist; ~/.claude-pt-ai-home.json is bind-mounted at the
    # container's $HOME/.claude.json (where Claude Code stores auth +
    # MCP config). The entrypoint registers the MCP bridge (pointing at the remote Kali server) in that file at
    # startup, so no separate mcp.json mount is needed.
    auth_args=""
    if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
        auth_args="-e ANTHROPIC_API_KEY"
    elif [ -f "$HOST_AUTH_DIR/.credentials.json" ]; then
        [ -f "$HOST_AUTH_FILE" ] || printf '{}' > "$HOST_AUTH_FILE"
        auth_args="-v $HOST_AUTH_DIR:/home/operator/.claude"
        auth_args="$auth_args -v $HOST_AUTH_FILE:/home/operator/.claude.json"
    else
        echo "ptai run: no authentication available." >&2
        echo "  Either export ANTHROPIC_API_KEY, or run 'ptai auth' first." >&2
        exit 1
    fi

    listen_args=""
    if [ -n "$listen_port" ]; then
        listen_args="-p ${listen_port}:${listen_port}"
    fi

    if [ "$shell_mode" = "1" ]; then
        cmd_in="/bin/bash"
    elif [ -n "$extra_args" ]; then
        cmd_in="claude $extra_args"
    else
        cmd_in="claude"
    fi

    # shellcheck disable=SC2086
    exec docker run --rm -it \
        --init \
        --name "pt-ai-${eng_id}-$(date +%s)" \
        --hostname pt-ai \
        --add-host=host.docker.internal:host-gateway \
        -e PT_AI_MCP_SERVER \
        $auth_args \
        $listen_args \
        -v "$eng_dir:/work" \
        -v "$REPO_DIR/agents:/home/operator/.claude/agents:ro" \
        -v "$REPO_DIR/skills:/home/operator/.claude/skills:ro" \
        "$IMAGE" \
        sh -c "$cmd_in"
}

if [ "$#" -lt 1 ]; then
    usage
    exit 1
fi

sub="$1"; shift
case "$sub" in
    build)         cmd_build "$@" ;;
    auth)          cmd_auth "$@" ;;
    run)           cmd_run "$@" ;;
    -h|--help|help) usage ;;
    *)
        echo "ptai: unknown command: $sub" >&2
        usage
        exit 1
        ;;
esac
