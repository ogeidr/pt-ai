#!/bin/sh
# ptai-ollama: host wrapper for the pt-ai Ollama ephemeral container.
#
# Subcommands:
#   build                          Build the image (always with --pull).
#   run <engagement-id> [opts]     Launch an ephemeral container for an engagement.
#                                    --shell           drop to bash instead of opencode
#                                    --listen <port>   publish a host port for callbacks
#
# Required env at run time:
#   PT_AI_OLLAMA_MODEL   model name as pulled in Ollama (e.g. gemma4:31b)
#   PT_AI_MCP_SERVER     URL of the remote kali-server-mcp API
#                        (e.g. http://host.docker.internal:5000 via SSH tunnel)
#
# Optional env:
#   PT_AI_OLLAMA_URL     Ollama base URL (default: http://host.docker.internal:11434)
#   UBUNTU_TAG           base image tag (default: 24.04)
#   MCP_BRIDGE_REF       git ref for the MCP bridge (default: main)
#   PT_AI_OLLAMA_IMAGE   image name (default: pt-ai-ollama:latest)
#
set -eu

SCRIPT="$0"
case "$SCRIPT" in
    /*) ;;
    *)  SCRIPT="$PWD/$SCRIPT" ;;
esac
DOCKER_DIR=$(cd "$(dirname "$SCRIPT")" && pwd)
REPO_DIR=$(cd "$DOCKER_DIR/.." && pwd)

IMAGE="${PT_AI_OLLAMA_IMAGE:-pt-ai-ollama:latest}"
UBUNTU_TAG="${UBUNTU_TAG:-24.04}"
MCP_BRIDGE_REF="${MCP_BRIDGE_REF:-main}"

usage() {
    cat <<EOF
Usage: ptai-ollama <command> [options]

Commands:
  build                          Build the pt-ai-ollama image
  run <engagement-id> [opts]     Launch ephemeral container for an engagement
                                   --shell           drop to bash instead of opencode
                                   --listen <port>   publish a host port for callbacks

Required env:
  PT_AI_OLLAMA_MODEL   model name as pulled in Ollama (e.g. gemma4:31b)
  PT_AI_MCP_SERVER     URL of the remote kali-server-mcp API
                       (e.g. http://host.docker.internal:5000)

Optional env:
  PT_AI_OLLAMA_URL     Ollama base URL (default: http://host.docker.internal:11434)
  UBUNTU_TAG           override base image tag (default: 24.04)
  MCP_BRIDGE_REF       upstream git ref for the MCP bridge (default: main)
  PT_AI_OLLAMA_IMAGE   override image name (default: pt-ai-ollama:latest)
EOF
}

cmd_build() {
    no_cache=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --no-cache) no_cache="--no-cache" ;;
            -h|--help)
                echo "Usage: ptai-ollama build [--no-cache]"
                return 0
                ;;
            *)
                echo "ptai-ollama build: unknown option: $1" >&2
                exit 1
                ;;
        esac
        shift
    done
    # shellcheck disable=SC2086
    docker build --pull $no_cache \
        --build-arg "UBUNTU_TAG=${UBUNTU_TAG}" \
        --build-arg "MCP_BRIDGE_REF=${MCP_BRIDGE_REF}" \
        -t "$IMAGE" \
        -f "$DOCKER_DIR/Dockerfile.ollama" \
        "$DOCKER_DIR"
}

cmd_run() {
    if [ "$#" -lt 1 ]; then
        echo "ptai-ollama run: missing <engagement-id>" >&2
        usage
        exit 1
    fi
    eng_id="$1"; shift

    if [ -z "${PT_AI_OLLAMA_MODEL:-}" ]; then
        echo "ptai-ollama run: PT_AI_OLLAMA_MODEL is required." >&2
        echo "  Set it to the model name you pulled with ollama pull." >&2
        echo "  Example: export PT_AI_OLLAMA_MODEL=gemma4:31b" >&2
        exit 1
    fi

    if [ -z "${PT_AI_MCP_SERVER:-}" ]; then
        echo "ptai-ollama run: PT_AI_MCP_SERVER is required." >&2
        echo "  Example: export PT_AI_MCP_SERVER=http://host.docker.internal:5000" >&2
        exit 1
    fi

    shell_mode=0
    listen_port=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --shell)  shell_mode=1 ;;
            --listen)
                shift
                if [ "$#" -lt 1 ]; then
                    echo "ptai-ollama run: --listen requires a port" >&2
                    exit 1
                fi
                listen_port="$1"
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "ptai-ollama run: unknown option: $1" >&2
                exit 1
                ;;
        esac
        shift
    done

    eng_dir="$REPO_DIR/engagements/$eng_id"
    mkdir -p "$eng_dir"

    listen_args=""
    if [ -n "$listen_port" ]; then
        listen_args="-p ${listen_port}:${listen_port}"
    fi

    ollama_url_arg=""
    if [ -n "${PT_AI_OLLAMA_URL:-}" ]; then
        ollama_url_arg="-e PT_AI_OLLAMA_URL"
    fi

    if [ "$shell_mode" = "1" ]; then
        cmd_in="/bin/bash"
    else
        cmd_in="opencode"
    fi

    # shellcheck disable=SC2086
    exec docker run --rm -it \
        --init \
        --name "pt-ai-ollama-${eng_id}-$(date +%s)" \
        --hostname pt-ai-ollama \
        --add-host=host.docker.internal:host-gateway \
        -e PT_AI_OLLAMA_MODEL \
        -e PT_AI_MCP_SERVER \
        -e OPENAI_API_KEY=ollama \
        $ollama_url_arg \
        $listen_args \
        -v "$eng_dir:/work" \
        -v "$REPO_DIR/agents:/opt/pt-ai/agents:ro" \
        -v "$REPO_DIR/commands:/opt/pt-ai/commands:ro" \
        "$IMAGE" \
        sh -c "$cmd_in"
}

if [ "$#" -lt 1 ]; then
    usage
    exit 1
fi

sub="$1"; shift
case "$sub" in
    build)          cmd_build "$@" ;;
    run)            cmd_run "$@" ;;
    -h|--help|help) usage ;;
    *)
        echo "ptai-ollama: unknown command: $sub" >&2
        usage
        exit 1
        ;;
esac
