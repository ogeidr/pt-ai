# syntax=docker/dockerfile:1.6
#
# pt-ai-lmstudio: ephemeral Ubuntu container running opencode + the vendored
# MCP stdio bridge.
#
# opencode speaks OpenAI-compatible APIs natively; it connects directly to
# LM Studio running on the host — no translation proxy needed.
# The Kali toolset and MCP API server live on a separate Linux host — identical
# to the standard pt-ai setup.
#
# Build-args:
#   UBUNTU_TAG       base image tag (default 24.04)
#   MCP_BRIDGE_REPO  upstream repo for the MCP bridge
#   MCP_BRIDGE_REF   git ref to checkout (default main; pin to a SHA for reproducibility)
#
ARG UBUNTU_TAG=24.04
FROM ubuntu:${UBUNTU_TAG}

ARG VERSION=dev
ARG MCP_BRIDGE_REPO=https://github.com/Wh0am123/MCP-Kali-Server.git
ARG MCP_BRIDGE_REF=main

LABEL org.opencontainers.image.title="pt-ai-lmstudio" \
      org.opencontainers.image.description="Ephemeral Ubuntu container with opencode and the MCP bridge" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.version="${VERSION}"

ENV DEBIAN_FRONTEND=noninteractive \
    HOME=/home/operator \
    PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin

# Base utilities + Node 20 + Python with venv support.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates curl git jq \
        python3 python3-pip python3-venv \
 && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
 && apt-get install -y --no-install-recommends nodejs \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

# opencode CLI.
RUN npm install -g opencode-ai@latest

# Vendor the MCP stdio bridge (same as Dockerfile).
RUN git clone "${MCP_BRIDGE_REPO}" /opt/mcp-bridge \
 && cd /opt/mcp-bridge \
 && git checkout "${MCP_BRIDGE_REF}" \
 && git rev-parse HEAD > /opt/mcp-bridge/.commit \
 && python3 -m venv /opt/mcp-bridge/.venv \
 && /opt/mcp-bridge/.venv/bin/pip install --no-cache-dir -r requirements.txt \
 && rm -rf /opt/mcp-bridge/.git

# Non-root operator user (uid 1000). Same uid as the standard image so
# engagement evidence directories are owned consistently on the host.
RUN userdel -r ubuntu 2>/dev/null || true \
 && useradd -m -s /bin/bash -u 1000 -g operator operator \
 && mkdir -p /home/operator/.config/opencode /work \
 && chown -R operator:operator /home/operator /work

COPY entrypoint-lmstudio.sh /usr/local/bin/entrypoint-lmstudio.sh
RUN chmod 755 /usr/local/bin/entrypoint-lmstudio.sh

USER operator
WORKDIR /work

ENTRYPOINT ["/usr/local/bin/entrypoint-lmstudio.sh"]
CMD ["opencode"]
