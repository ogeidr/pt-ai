# Copy to .env and source before using the VM.
# cp engagement.env.example .env && source .env

# --- Authentication ----------------------------------------------------------
#
# Option A: API key auth (Anthropic API — bills against your key).
#
#   Session-only (key forwarded per run, never stored in VM):
#     export ANTHROPIC_API_KEY=sk-ant-...
#     ./pt-ai claude
#
#   Persistent (stored in VM, picked up by all future sessions):
#     export ANTHROPIC_API_KEY=sk-ant-...
#     ./pt-ai key store
#
# export ANTHROPIC_API_KEY=sk-ant-...

# Option B: OAuth (Claude Pro/Max — no key needed).
#   Just run ./pt-ai claude on first boot; follow the browser prompt.
#   No variable needed.
#
# Note: opencode (./pt-ai opencode) does NOT consume Claude Code's OAuth tokens.
# It requires ANTHROPIC_API_KEY (session-forwarded or ./pt-ai key store'd) and
# bills against your API key, not a Pro/Max subscription.

# --- opencode ----------------------------------------------------------------
# Override opencode's default model (default: anthropic/claude-sonnet-4-6).
# export PT_AI_OPENCODE_MODEL=anthropic/claude-opus-4-7

# --- VM resources ------------------------------------------------------------
# export VAGRANT_MEMORY=8192
# export VAGRANT_CPUS=8

# --- Box selection -----------------------------------------------------------
# Kali by default. Any apt-family box works (Ubuntu, Debian, Parrot, Mint…);
# Kali-specific steps auto-skip on non-Kali guests. KALI_BOX is still honored
# for back-compat.
# export PTAI_BOX=ubuntu/jammy
#
# Skip the Ghidra-backed RE tools (independent; each downloads/builds Ghidra):
# export PTAI_SKIP_GHIDRASQL=1     # ghidrasql (SQL over Ghidra)
# export PTAI_SKIP_GHIDRA_RPC=1    # ghidra-rpc (PyGhidra RE daemon)

# --- Provider (Apple Silicon) ------------------------------------------------
# export VAGRANT_PROVIDER=vmware_desktop
# export PTAI_BOX=kali-arm64
