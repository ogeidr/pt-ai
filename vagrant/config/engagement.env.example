# Copy to .env and source before using the VM.
# cp engagement.env.example .env && source .env

# Optional: Anthropic API key for API key auth (forwarded into the VM via SSH).
# Claude Pro users can leave this unset and authenticate via OAuth on first run.
# export ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override VM resources
# export VAGRANT_MEMORY=8192
# export VAGRANT_CPUS=8

# Optional: Switch provider (vmware_desktop for ARM64 / Apple Silicon)
# export VAGRANT_PROVIDER=vmware_desktop
# export KALI_BOX=kali-arm64
