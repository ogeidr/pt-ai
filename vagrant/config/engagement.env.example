# Copy to .env and source before using the VM.
# cp engagement.env.example .env && source .env

# --- Authentication ----------------------------------------------------------
#
# Option A: API key auth (Anthropic API — bills against your key).
#
#   Session-only (key forwarded per run, never stored in VM):
#     export ANTHROPIC_API_KEY=sk-ant-...
#     ./kali claude
#
#   Persistent (stored in VM, picked up by all future sessions):
#     export ANTHROPIC_API_KEY=sk-ant-...
#     ./kali key store
#
# export ANTHROPIC_API_KEY=sk-ant-...

# Option B: OAuth (Claude Pro/Max — no key needed).
#   Just run ./kali claude on first boot; follow the browser prompt.
#   No variable needed.

# --- VM resources ------------------------------------------------------------
# export VAGRANT_MEMORY=8192
# export VAGRANT_CPUS=8

# --- Provider (Apple Silicon) ------------------------------------------------
# export VAGRANT_PROVIDER=vmware_desktop
# export KALI_BOX=kali-arm64
