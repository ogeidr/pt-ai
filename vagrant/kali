#!/bin/sh
# kali: host wrapper for the pt-ai Vagrant Kali VM.
#
# Mirrors the docker/ptai pattern: one command for the full VM lifecycle.
#
# Subcommands:
#   up                  Boot VM (provision on first run)
#   ssh                 Interactive shell inside the VM
#   claude [-- <args>]  Start Claude Code inside the VM
#   key <store|clear|status>  Manage a persistent API key inside the VM
#   snapshot <name>     Save a VM snapshot
#   restore  <name>     Restore a VM snapshot
#   halt                Shut down the VM
#   destroy             Destroy the VM (irreversible)
#   provision           Re-run all provisioners
#   status              Show VM status
#
# Authentication:
#   Two methods, matching the Docker deployments.
#
#   Option A — API key (session forwarding):
#     export ANTHROPIC_API_KEY=sk-ant-...
#     ./kali claude
#     The key is written to a short-lived temp file in the VM for the session
#     duration and deleted when Claude exits.  Never stored at rest.
#
#   Option B — API key (persistent, stored in VM):
#     export ANTHROPIC_API_KEY=sk-ant-...
#     ./kali key store      # writes key to ~/.anthropic_key inside the VM
#     ./kali claude         # all subsequent sessions pick it up automatically
#     ./kali key clear      # remove when no longer needed
#
#   Option C — OAuth (Claude Pro/Max, no API key):
#     ./kali claude         # first run prints a URL; open in host browser
#                           # credentials persist in ~/.claude/ across sessions
#
#   Precedence (handled by Claude Code): API key > stored OAuth credentials.
#
# Environment overrides:
#   ANTHROPIC_API_KEY   Optional — forwarded if set (Options A/B)
#   KALI_BOX            Vagrant box name (default: kalilinux/rolling)
#   VAGRANT_PROVIDER    virtualbox | vmware_desktop | parallels (default: virtualbox)
#   VAGRANT_MEMORY      VM memory MB (default: 4096)
#   VAGRANT_CPUS        vCPU count (default: 4)
#
# ARM64 (Apple Silicon):
#   Build the box first: ./box/build.sh
#   Then: KALI_BOX=kali-arm64 VAGRANT_PROVIDER=vmware_desktop ./kali up
#
set -eu

SCRIPT="$0"
case "$SCRIPT" in
    /*) ;;
    *)  SCRIPT="$PWD/$SCRIPT" ;;
esac
VAGRANT_DIR=$(cd "$(dirname "$SCRIPT")" && pwd)

KALI_BOX="${KALI_BOX:-kalilinux/rolling}"
VAGRANT_PROVIDER="${VAGRANT_PROVIDER:-virtualbox}"
VAGRANT_MEMORY="${VAGRANT_MEMORY:-4096}"
VAGRANT_CPUS="${VAGRANT_CPUS:-4}"

# Run vagrant with the correct env from the vagrant/ dir
_vagrant() {
    ( cd "$VAGRANT_DIR" && \
      env \
        KALI_BOX="$KALI_BOX" \
        VAGRANT_PROVIDER="$VAGRANT_PROVIDER" \
        VAGRANT_MEMORY="$VAGRANT_MEMORY" \
        VAGRANT_CPUS="$VAGRANT_CPUS" \
      vagrant "$@" )
}

usage() {
    cat <<EOF
Usage: kali <command> [options]

Commands:
  up                     Boot VM (provision on first run)
  ssh                    Interactive shell inside VM
  claude [-- <args>]     Start Claude Code inside VM
  key store              Store ANTHROPIC_API_KEY from host env into VM
  key clear              Remove stored API key from VM
  key status             Show whether an API key is stored in VM
  snapshot <name>        Save a VM snapshot
  restore  <name>        Restore a VM snapshot
  halt                   Shut down the VM
  destroy                Destroy the VM and all its state
  provision              Re-run all provisioners
  status                 Show VM status

Auth:
  API key (session):     export ANTHROPIC_API_KEY=sk-ant-... && ./kali claude
  API key (persistent):  export ANTHROPIC_API_KEY=sk-ant-... && ./kali key store
  OAuth (Pro/Max):       ./kali claude  (URL printed on first run)

Environment:
  ANTHROPIC_API_KEY    Optional — forwarded per-session if set
  KALI_BOX             Box name (default: kalilinux/rolling)
  VAGRANT_PROVIDER     virtualbox | vmware_desktop | parallels (default: virtualbox)
  VAGRANT_MEMORY       VM RAM in MB (default: 4096)
  VAGRANT_CPUS         vCPU count (default: 4)

ARM64 hosts:
  Build the box first: ./box/build.sh
  Then: KALI_BOX=kali-arm64 VAGRANT_PROVIDER=vmware_desktop ./kali up
EOF
}

cmd_up() {
    _vagrant up --provider "$VAGRANT_PROVIDER" "$@"
}

cmd_ssh() {
    _vagrant ssh "$@"
}

cmd_claude() {
    extra_args=""
    if [ "$#" -gt 0 ] && [ "$1" = "--" ]; then
        shift
        extra_args="$*"
    fi

    base_cmd="claude${extra_args:+ $extra_args}"

    if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
        # Write key to a short-lived temp file in the VM (chmod 600), read it
        # at session start, then delete it.  Avoids SSH SendEnv fragility and
        # keeps the key out of the remote process listing.
        _vagrant ssh -- "bash -c 'printf \"%s\" \"${ANTHROPIC_API_KEY}\" > /tmp/.ptai-key && chmod 600 /tmp/.ptai-key'"
        claude_cmd="export ANTHROPIC_API_KEY=\$(cat /tmp/.ptai-key) && rm -f /tmp/.ptai-key && $base_cmd"
    else
        claude_cmd="$base_cmd"
    fi

    # Login shell (-l) so /etc/profile.d/pt-ai.sh is sourced (PATH, PS1, stored key).
    # shellcheck disable=SC2086
    _vagrant ssh -- -t "bash -l -c 'cd /engagements && $claude_cmd'"
}

cmd_key() {
    action="${1:-}"
    case "$action" in
        store)
            if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
                echo "kali key store: ANTHROPIC_API_KEY is not set in the host environment" >&2
                exit 1
            fi
            _vagrant ssh -- "bash -c 'printf \"export ANTHROPIC_API_KEY=%s\n\" \"${ANTHROPIC_API_KEY}\" > ~/.anthropic_key && chmod 600 ~/.anthropic_key'"
            echo "API key stored in VM (~/.anthropic_key)."
            echo "All subsequent './kali claude' sessions will use it."
            echo "Run './kali key clear' to remove it."
            ;;
        clear)
            _vagrant ssh -- "rm -f ~/.anthropic_key"
            echo "API key removed from VM. Sessions will fall back to OAuth."
            ;;
        status)
            if _vagrant ssh -- "test -f ~/.anthropic_key" 2>/dev/null; then
                echo "API key: stored in VM (./kali key clear to remove)"
            else
                echo "API key: not stored — using OAuth or per-session forwarding"
            fi
            ;;
        *)
            echo "Usage: kali key <store|clear|status>" >&2
            exit 1
            ;;
    esac
}

cmd_snapshot() {
    if [ "$#" -lt 1 ]; then
        echo "kali snapshot: missing <name>" >&2; exit 1
    fi
    _vagrant snapshot save "$1"
}

cmd_restore() {
    if [ "$#" -lt 1 ]; then
        echo "kali restore: missing <name>" >&2; exit 1
    fi
    _vagrant snapshot restore "$1"
}

cmd_halt()      { _vagrant halt; }
cmd_destroy()   { _vagrant destroy -f; }
cmd_provision() { _vagrant provision; }
cmd_status()    { _vagrant status; }

if [ "$#" -lt 1 ]; then
    usage; exit 1
fi

sub="$1"; shift
case "$sub" in
    up)             cmd_up "$@" ;;
    ssh)            cmd_ssh "$@" ;;
    claude)         cmd_claude "$@" ;;
    key)            cmd_key "$@" ;;
    snapshot)       cmd_snapshot "$@" ;;
    restore)        cmd_restore "$@" ;;
    halt)           cmd_halt ;;
    destroy)        cmd_destroy ;;
    provision)      cmd_provision ;;
    status)         cmd_status ;;
    -h|--help|help) usage ;;
    *)
        echo "kali: unknown command: $sub" >&2
        usage; exit 1
        ;;
esac
