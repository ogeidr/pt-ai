# Box selection: PTAI_BOX is the primary var; KALI_BOX is still honored for
# back-compat. Any apt-family box works — Kali-specific provisioning auto-skips
# on non-Kali guests (see provision/_lib.sh).
BOX             = ENV.fetch("PTAI_BOX") { ENV.fetch("KALI_BOX", "kalilinux/rolling") }
VAGRANT_PROVIDER = ENV.fetch("VAGRANT_PROVIDER", "virtualbox")
VM_MEMORY       = ENV.fetch("VAGRANT_MEMORY",   "4096").to_i
VM_CPUS         = ENV.fetch("VAGRANT_CPUS",     "4").to_i

# Two Ghidra-backed tools are provisioned side by side so they can be A/B tested
# against the same binary. Both are heavy (each can download Ghidra; on aarch64
# the native decompiler is built once and reused) — each is independently
# opt-out. They share /opt/ghidra_<ver>_PUBLIC, so whichever runs first does the
# download/build and the other reuses it.
GHIDRASQL_ENABLED  = ENV.fetch("PTAI_SKIP_GHIDRASQL",  "").strip.empty?
GHIDRA_RPC_ENABLED = ENV.fetch("PTAI_SKIP_GHIDRA_RPC", "").strip.empty?

Vagrant.configure("2") do |config|
  config.vm.box      = BOX
  # hostname is set by the inline provisioner below; not set here because
  # Vagrant's built-in hostname setter fails when / is still mounted read-only
  # on first boot after box cloning.

  # --- Providers -----------------------------------------------------------
  # Select with: VAGRANT_PROVIDER=vmware_desktop ./pt-ai up
  config.vm.provider "virtualbox" do |v|
    v.name   = "kali-ptai"
    v.memory = VM_MEMORY
    v.cpus   = VM_CPUS
    v.gui    = false
    v.customize ["modifyvm", :id, "--natdnshostresolver1", "on"]
  end

  config.vm.provider "vmware_desktop" do |v|
    v.vmx["memsize"]   = VM_MEMORY.to_s
    v.vmx["numvcpus"]  = VM_CPUS.to_s
    v.gui              = false
    v.allowlist_verified = true
  end

  config.vm.provider "parallels" do |v|
    v.name   = "kali-ptai"
    v.memory = VM_MEMORY
    v.cpus   = VM_CPUS
  end

  # --- Synced folders -------------------------------------------------------
  # engagements/ is the shared workspace; agents/ and skills/ are read-only
  # references synced from the repo into the VM. opencode commands are
  # derived from both at provision time (see provision/05-opencode.sh).
  config.vm.synced_folder "../engagements", "/engagements", create: true
  config.vm.synced_folder "../agents",      "/opt/pt-ai/agents"
  config.vm.synced_folder "../skills",      "/opt/pt-ai/skills"

  # Private network for host <-> VM access without NAT overhead
  config.vm.network "private_network", type: "dhcp"

  # --- Provisioners (run once on first `vagrant up`) -----------------------
  # Ensure root is mounted read-write before any other provisioner runs.
  # On first boot after box cloning the filesystem may be remounted ro by fsck.
  config.vm.provision "shell", inline: <<~SHELL
    mount -o remount,rw / 2>/dev/null || true
    echo "kali-ptai" > /etc/hostname
    hostname kali-ptai
    grep -q "kali-ptai" /etc/hosts || echo "127.0.1.1 kali-ptai" >> /etc/hosts
    # Override broken VMware NAT DNS before any provisioner touches the network.
    # Write directly to resolv.conf (immediate) and resolv.conf.head (persists
    # across DHCP renewals).
    printf 'nameserver 8.8.8.8\nnameserver 8.8.4.4\n' > /etc/resolv.conf
    printf 'nameserver 8.8.8.8\nnameserver 8.8.4.4\n' > /etc/resolv.conf.head
    # Remove legacy /work/ directory (replaced by /engagements/{id}/ in scope-declare).
    rm -rf /work
  SHELL

  config.vm.provision "shell", path: "provision/00-update.sh"

  config.vm.provision "shell",
    path: "provision/01-tools.sh",
    args: ["/vagrant/config/tools.txt"]

  config.vm.provision "shell", path: "provision/02-claude.sh"

  config.vm.provision "shell", path: "provision/03-network.sh"

  config.vm.provision "shell", path: "provision/04-harden.sh"

  config.vm.provision "shell", path: "provision/05-opencode.sh"

  config.vm.provision "shell", path: "provision/06-cloud.sh"

  # ghidrasql — SQL/HTTP interface over Ghidra program DBs. Heavy: downloads
  # Ghidra and, on aarch64, builds the native decompiler from source.
  # Opt out with PTAI_SKIP_GHIDRASQL=1.
  if GHIDRASQL_ENABLED
    config.vm.provision "shell", path: "provision/07-ghidrasql.sh"
  end

  # ghidra-rpc — agent-driven RE daemon over Ghidra (PyGhidra). Runs alongside
  # ghidrasql for comparison; reuses the same Ghidra install. Heavy on first run.
  # Opt out with PTAI_SKIP_GHIDRA_RPC=1.
  if GHIDRA_RPC_ENABLED
    config.vm.provision "shell", path: "provision/08-ghidra-rpc.sh"
  end
end
