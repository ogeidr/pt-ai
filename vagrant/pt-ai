#!/bin/sh
# pt-ai: host wrapper for the pt-ai Vagrant Kali VM.
#
# Mirrors the docker/ptai pattern: one command for the full VM lifecycle.
#
# Subcommands:
#   up                  Boot VM (provision on first run)
#   ssh                 Interactive shell inside the VM
#   claude [-- <args>]  Start Claude Code inside the VM
#   opencode [-- <args>] Start opencode inside the VM (Anthropic provider)
#   local-model <detect|use>  Point opencode at a host-served local model (durable)
#   key <store|clear|status>  Manage a persistent API key inside the VM
#   snapshot list       List saved VM snapshots
#   snapshot <name>     Save a VM snapshot
#   restore  <name>     Restore a VM snapshot
#   halt                Shut down the VM
#   destroy             Destroy the VM (irreversible)
#   provision           Re-run all provisioners
#   status              Show VM status
#
# Authentication:
#   Two methods, matching the Docker deployments.
#
#   Option A — API key (session forwarding):
#     export ANTHROPIC_API_KEY=sk-ant-...
#     ./pt-ai claude
#     The key is written to a short-lived temp file in the VM for the session
#     duration and deleted when Claude exits.  Never stored at rest.
#
#   Option B — API key (persistent, stored in VM):
#     export ANTHROPIC_API_KEY=sk-ant-...
#     ./pt-ai key store      # writes key to ~/.anthropic_key inside the VM
#     ./pt-ai claude         # all subsequent sessions pick it up automatically
#     ./pt-ai key clear      # remove when no longer needed
#
#   Option C — OAuth (Claude Pro/Max, no API key):
#     ./pt-ai claude         # first run prints a URL; open in host browser
#                           # credentials persist in ~/.claude/ across sessions
#
#   Precedence (handled by Claude Code): API key > stored OAuth credentials.
#
#   opencode auth note:
#     opencode does NOT consume Claude Code's ~/.claude/ OAuth tokens.  It needs
#     ANTHROPIC_API_KEY (either session-forwarded, './pt-ai key store'd, or set
#     via 'opencode auth login anthropic' inside the VM).  Pro/Max subscription
#     usage runs through Claude Code only — opencode bills against the API key.
#
# Environment overrides:
#   ANTHROPIC_API_KEY     Optional — forwarded if set (Options A/B); used by
#                         both Claude Code and opencode
#   PT_AI_OPENCODE_MODEL  Optional — overrides opencode's default model
#                         (default in opencode.json: anthropic/claude-sonnet-4-6)
#   PT_AI_OPENCODE_ALLOW_FALLBACK
#                         Optional — set to 1 to skip the prompt and allow
#                         opencode's hosted default model when no local/cloud
#                         model is reachable (default: abort; never auto-fall-back)
#   PTAI_BOX              Vagrant box name (default: kalilinux/rolling). Any
#                         apt-family box works; Kali-only steps auto-skip.
#                         KALI_BOX is still honored as a fallback.
#   VAGRANT_PROVIDER      vmware_desktop | virtualbox | parallels (default: vmware_desktop)
#   VAGRANT_MEMORY        VM memory MB (default: 4096)
#   VAGRANT_CPUS          vCPU count (default: 4)
#
# ARM64 (Apple Silicon):
#   Build the box first: ./box/build.sh
#   Then: PTAI_BOX=kali-arm64 VAGRANT_PROVIDER=vmware_desktop ./pt-ai up
#
set -eu

SCRIPT="$0"
case "$SCRIPT" in
    /*) ;;
    *)  SCRIPT="$PWD/$SCRIPT" ;;
esac
VAGRANT_DIR=$(cd "$(dirname "$SCRIPT")" && pwd)

# Host path of the engagements synced_folder (../engagements relative to vagrant/).
# Engagement data (findings.jsonl, evidence, scope.md) lives here in plaintext on
# the host disk; `pt-ai engagement purge` is the teardown path for it.
ENGAGEMENTS_DIR="$VAGRANT_DIR/../engagements"

# PTAI_BOX is primary; KALI_BOX kept as a back-compat fallback.
PTAI_BOX="${PTAI_BOX:-${KALI_BOX:-kalilinux/rolling}}"
VAGRANT_PROVIDER="${VAGRANT_PROVIDER:-vmware_desktop}"
VAGRANT_MEMORY="${VAGRANT_MEMORY:-4096}"
VAGRANT_CPUS="${VAGRANT_CPUS:-4}"

# Run vagrant with the correct env from the vagrant/ dir
_vagrant() {
    ( cd "$VAGRANT_DIR" && \
      env \
        PTAI_BOX="$PTAI_BOX" \
        VAGRANT_PROVIDER="$VAGRANT_PROVIDER" \
        VAGRANT_MEMORY="$VAGRANT_MEMORY" \
        VAGRANT_CPUS="$VAGRANT_CPUS" \
      vagrant "$@" )
}

# POSIX-safe shell quoting: wrap each argument in single quotes (escaping any
# embedded single quote as '\'') so spaces, quotes, parens, '*', and SQL bodies
# survive being re-parsed by the remote shell. Pure parameter expansion — no
# bashisms, no sed. Output has a leading space (harmless).
_shquote() {
    _sq_out=
    for _sq_arg in "$@"; do
        _sq_q="'"
        _sq_rest=$_sq_arg
        while case $_sq_rest in *\'*) true ;; *) false ;; esac; do
            _sq_q="$_sq_q${_sq_rest%%\'*}'\\''"
            _sq_rest=${_sq_rest#*\'}
        done
        _sq_out="$_sq_out $_sq_q$_sq_rest'"
    done
    printf '%s' "$_sq_out"
}

usage() {
    cat <<EOF
Usage: pt-ai <command> [options]

Commands:
  up                     Boot VM (provision on first run)
  ssh                    Interactive shell inside VM
  claude [--fresh] [-- <args>]    Start Claude Code inside VM (--fresh wipes prior session history)
  opencode [--fresh] [-- <args>]  Start opencode inside VM (--fresh wipes prior session history)
  local-model detect     Find reachable local model endpoints (LM Studio/Ollama)
  local-model use <id>   Point opencode at a local model (durable across re-provision)
  key store              Store ANTHROPIC_API_KEY from host env into VM
  key clear              Remove stored API key from VM
  key status             Show whether an API key is stored in VM
  engagement list        List engagements and their on-disk sizes
  engagement purge <id>  Delete one engagement's data (add -y to skip the prompt)
  engagement purge --all Delete all engagement data
  snapshot list          List saved VM snapshots
  snapshot <name>        Save a VM snapshot
  restore  <name>        Restore a VM snapshot
  halt                   Shut down the VM
  destroy                Destroy the VM and all its state
  provision              Re-run all provisioners
  status                 Show VM status

Auth:
  API key (session):     export ANTHROPIC_API_KEY=sk-ant-... && ./pt-ai claude
  API key (persistent):  export ANTHROPIC_API_KEY=sk-ant-... && ./pt-ai key store
  OAuth (Pro/Max):       ./pt-ai claude  (URL printed on first run)

Environment:
  ANTHROPIC_API_KEY    Optional — forwarded per-session if set
                       (shared between claude and opencode)
  PT_AI_OPENCODE_MODEL Optional — overrides opencode's default model
  PT_AI_OPENCODE_ALLOW_FALLBACK
                       Optional — set to 1 to allow opencode's hosted default
                       model without prompting (default: abort if no local model)
  PTAI_BOX             Box name (default: kalilinux/rolling). Any apt-family
                       box works; Kali-only steps auto-skip. KALI_BOX honored
                       as a fallback.
  VAGRANT_PROVIDER     vmware_desktop | virtualbox | parallels (default: vmware_desktop)
  VAGRANT_MEMORY       VM RAM in MB (default: 4096)
  VAGRANT_CPUS         vCPU count (default: 4)

ARM64 hosts:
  Build the box first: ./box/build.sh
  Then: PTAI_BOX=kali-arm64 VAGRANT_PROVIDER=vmware_desktop ./pt-ai up
EOF
}

cmd_up() {
    _vagrant up --provider "$VAGRANT_PROVIDER" "$@"
}

# Ensure the VM is booted and SSH-ready before an interactive session.
# claude/opencode/ssh call `vagrant ssh` directly; against a halted, saved,
# or not-yet-created machine that prints an opaque "not yet ready for SSH"
# error. Probe first (same idiom as _lm_use, below); boot on demand if it
# fails — `vagrant up` blocks until the machine is booted and SSH-ready, so a
# real session follows cleanly.
_ensure_up() {
    _vagrant ssh -- -T true </dev/null >/dev/null 2>&1 && return 0
    echo "[pt-ai] VM not ready — booting it first (./pt-ai up)…" >&2
    cmd_up
}

cmd_ssh() {
    _ensure_up
    _vagrant ssh "$@"
}

cmd_claude() {
    # --fresh (PENDING #20): wipe cross-engagement Claude state before launch —
    # ~/.claude/projects + history.jsonl — preserving credentials and settings.
    # Must precede any `--`. Explicit opt-in (safer than auto-wipe-on-exit).
    _ensure_up
    fresh=0
    case "${1:-}" in --fresh) fresh=1; shift ;; esac
    if [ "$#" -gt 0 ] && [ "$1" = "--" ]; then shift; else set --; fi
    # Quote each user arg so `-- <args>` is inert data, not shell syntax. Without
    # this, `claude -- --x; rm -rf /engagements/*` would run `rm` inside the VM
    # (/engagements is a persistent host bind).
    qargs=$(_shquote "$@")

    wipe=''
    [ "$fresh" -eq 1 ] && wipe='echo "[pt-ai] --fresh: clearing Claude session history (credentials preserved)"; rm -rf ~/.claude/projects ~/.claude/todos ~/.claude/shell-snapshots; rm -f ~/.claude/history.jsonl; '

    if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
        # Write key to a short-lived temp file in the VM, read it at session
        # start, then delete it.  The key is streamed over SSH stdin (never
        # placed in argv), so it stays out of both the host and guest process
        # listings; `umask 077` makes the temp file 0600.
        printf '%s' "$ANTHROPIC_API_KEY" | \
            _vagrant ssh -- -T "umask 077; cat > /tmp/.ptai-key"
        key='export ANTHROPIC_API_KEY=$(cat /tmp/.ptai-key) && rm -f /tmp/.ptai-key && '
    else
        key=''
    fi

    # The command crosses TWO remote shell-parse layers: the remote login shell
    # (which extracts the `bash -c` argument) and the inner `bash -c`. qargs is
    # already quoted for the inner layer; _shquote the whole script again so it
    # survives the outer layer too. $(cat /tmp/.ptai-key) stays literal until the
    # inner bash runs it on the VM.
    script="cd /engagements && ${wipe}${key}claude$qargs"

    # Login shell (-l) so /etc/profile.d/pt-ai.sh is sourced (PATH, PS1, stored key).
    # shellcheck disable=SC2029
    _vagrant ssh -- -t "bash -l -c $(_shquote "$script")"
}

# --- local-model: configure opencode to use a host-served local model ----------
# Detects a reachable LM Studio (:1234) / Ollama (:11434) endpoint from inside the
# VM and writes a DURABLE provider config (config/opencode/local-model.json) that
# 05-opencode.sh merges on every provision — so the setup survives provision and
# destroy/up. Provider key in opencode.json is `local`; model becomes `local/<id>`.

# Probe the VM for reachable endpoints. $1 = space-separated ports (default both).
# Echoes one line per working endpoint: "<url>\t<comma-separated model ids>".
_lm_probe() {
    _lm_pp=$(_shquote "${1:-1234 11434}"); _lm_pp=${_lm_pp# }
    _lm_s=$(cat <<'EOF'
gw=$(ip route 2>/dev/null | awk '/default/{print $3; exit}')
for h in $gw 172.16.145.1 192.168.161.1 10.0.2.2; do
  [ -n "$h" ] || continue
  for p in $PORTS; do
    out=$(curl -sf -m 3 "http://$h:$p/v1/models" 2>/dev/null) || continue
    ids=$(printf '%s' "$out" | jq -r '.data[].id' 2>/dev/null | paste -sd, -)
    [ -n "$ids" ] && printf 'http://%s:%s/v1\t%s\n' "$h" "$p" "$ids"
  done
done
EOF
)
    _lm_sq=$(_shquote "$_lm_s"); _lm_sq=${_lm_sq# }
    # dedup by URL host-side (gateway may equal a static candidate).
    _vagrant ssh -- -T "PORTS=$_lm_pp bash -lc $_lm_sq" </dev/null 2>/dev/null \
        | tr -d '\r' | awk -F'\t' 'NF && !seen[$1]++'
}

# Comma-separated model ids served at a specific URL (used when --url is given).
_lm_ids_at() {
    _lm_uq=$(_shquote "$1"); _lm_uq=${_lm_uq# }
    _lm_s=$(cat <<'EOF'
curl -sf -m 3 "$URL/models" 2>/dev/null | jq -r '.data[].id' 2>/dev/null | paste -sd, -
EOF
)
    _lm_sq=$(_shquote "$_lm_s"); _lm_sq=${_lm_sq# }
    _vagrant ssh -- -T "URL=$_lm_uq bash -lc $_lm_sq" </dev/null 2>/dev/null | tr -d '\r'
}

# Merge the `local` provider into the running VM's opencode.json (same shape as
# the 05-opencode.sh provisioner merge, so live and provisioned configs match).
_lm_apply_live() {
    _lm_uq=$(_shquote "$1"); _lm_uq=${_lm_uq# }
    _lm_mq=$(_shquote "$2"); _lm_mq=${_lm_mq# }
    _lm_s=$(cat <<'EOF'
cfg="$HOME/.config/opencode/opencode.json"
tmp=$(mktemp)
jq --arg u "$URL" --arg m "$MODEL" '.provider.local={npm:"@ai-sdk/openai-compatible",options:{baseURL:$u},models:{($m):{name:$m}}} | .model=("local/"+$m)' "$cfg" > "$tmp" && mv "$tmp" "$cfg"
EOF
)
    _lm_sq=$(_shquote "$_lm_s"); _lm_sq=${_lm_sq# }
    _vagrant ssh -- -T "URL=$_lm_uq MODEL=$_lm_mq bash -lc $_lm_sq" </dev/null >/dev/null 2>&1
}

_lm_detect() {
    _ensure_up            # probing local-model endpoints runs inside the VM — boot it first
    _lm_port=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --port) _lm_port="$2"; shift 2 ;;
            *) echo "pt-ai local-model detect: unknown arg: $1" >&2; exit 1 ;;
        esac
    done
    echo "Probing the VM for reachable local-model endpoints..."
    _lm_out=$(_lm_probe "${_lm_port:-1234 11434}")
    if [ -z "$_lm_out" ]; then
        echo "No reachable endpoint (LM Studio :1234 / Ollama :11434)." >&2
        echo "Check: model server running on the host AND bound to all interfaces" >&2
        echo "(LM Studio: 'Serve on Local Network'); VM is up. Use --port for non-default." >&2
        exit 1
    fi
    _lm_tab=$(printf '\t')
    printf '%s\n' "$_lm_out" | while IFS="$_lm_tab" read -r _u _ids; do
        echo ""
        echo "  Endpoint: $_u"
        echo "  Models:"
        echo "$_ids" | tr ',' '\n' | sed 's/^/    /'
    done
    echo ""
    echo "Next: ./pt-ai local-model use <model-id>   (copy an exact id above)"
}

_lm_use() {
    _lm_url=""; _lm_port=""; _lm_model=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --url)  _lm_url="$2"; shift 2 ;;
            --port) _lm_port="$2"; shift 2 ;;
            -*)     echo "pt-ai local-model use: unknown flag: $1" >&2; exit 1 ;;
            *)      [ -z "$_lm_model" ] && _lm_model="$1"; shift ;;
        esac
    done
    [ -n "$_lm_model" ] || { echo "Usage: pt-ai local-model use <model-id> [--url URL] [--port N]" >&2; exit 1; }

    _lm_tab=$(printf '\t')
    if [ -n "$_lm_url" ]; then
        _u="$_lm_url"; _ids=$(_lm_ids_at "$_u")
    else
        _line=$(_lm_probe "${_lm_port:-1234 11434}" | head -n1)
        _u=${_line%%"$_lm_tab"*}; _ids=${_line#*"$_lm_tab"}
    fi
    [ -n "$_u" ] || { echo "No reachable endpoint; run './pt-ai local-model detect' or pass --url." >&2; exit 1; }

    # Verify the id is actually served (catches prefix/casing mistakes early).
    if [ -n "$_ids" ]; then
        case ",$_ids," in
            *",$_lm_model,"*) ;;
            *) echo "Model '$_lm_model' is not served at $_u. Available:" >&2
               echo "$_ids" | tr ',' '\n' | sed 's/^/  /' >&2
               exit 1 ;;
        esac
    fi

    # A) durable host config — survives provision and destroy/up.
    mkdir -p "$VAGRANT_DIR/config/opencode"
    printf '{ "url": "%s", "model": "%s" }\n' "$_u" "$_lm_model" \
        > "$VAGRANT_DIR/config/opencode/local-model.json"
    echo "Wrote config/opencode/local-model.json  ($_lm_model @ $_u)"

    # Apply now if the VM is up; otherwise it lands on the next up/provision.
    if _vagrant ssh -- -T "true" </dev/null >/dev/null 2>&1; then
        if _lm_apply_live "$_u" "$_lm_model"; then
            echo "Applied to the running VM. Launch with: ./pt-ai opencode"
        else
            echo "WARN: live apply failed; takes effect on next ./pt-ai provision." >&2
        fi
    else
        echo "VM not running — applies on next ./pt-ai up / provision."
    fi
}

cmd_local_model() {
    _lm_action="${1:-}"
    if [ "$#" -gt 0 ]; then shift; fi
    case "$_lm_action" in
        detect) _lm_detect "$@" ;;
        use)    _lm_use "$@" ;;
        *)
            echo "Usage: pt-ai local-model <detect|use>" >&2
            echo "  detect [--port N]                       Find reachable local model endpoints + ids" >&2
            echo "  use <model-id> [--url URL] [--port N]   Point opencode at it (durable)" >&2
            exit 1
            ;;
    esac
}

# Model preflight: decide whether opencode will run a usable LOCAL or cloud model,
# or silently fall back to opencode's hosted default ("Big Pickle"/Zen) — which
# sends prompts and engagement data off-machine. Echoes one of:
#   local-ok | local-down | cloud-ok | fallback   (empty if the VM check failed).
# The check runs INSIDE the VM, in the same network context the launch uses, so a
# tunnelled localhost endpoint is judged correctly. Detection is provider-agnostic:
# any provider with an options.baseURL is treated as a local/custom endpoint and
# health-checked; we never hardcode the (changing) Zen model name.
_opencode_preflight() {
    _pf_want="${PT_AI_OPENCODE_MODEL:-}"
    _pf_key=0
    [ -n "${ANTHROPIC_API_KEY:-}" ] && _pf_key=1
    _pf_check=$(cat <<'EOF'
cfg="$HOME/.config/opencode/opencode.json"
m="$WANT"; [ -n "$m" ] || m=$(jq -r '.model // empty' "$cfg" 2>/dev/null)
[ -n "$m" ] || { echo fallback; exit 0; }
p=${m%%/*}
url=$(jq -r --arg p "$p" '.provider[$p].options.baseURL // empty' "$cfg" 2>/dev/null)
if [ -n "$url" ]; then
  curl -sf -m 3 "$url/models" >/dev/null 2>&1 && echo local-ok || echo local-down
elif [ "$p" = anthropic ] && [ "$HAVEKEY" = 1 ]; then
  echo cloud-ok
else
  echo fallback
fi
EOF
)
    _pf_wq=$(_shquote "$_pf_want"); _pf_wq=${_pf_wq# }
    _pf_cq=$(_shquote "$_pf_check"); _pf_cq=${_pf_cq# }
    _vagrant ssh -- -T "WANT=$_pf_wq HAVEKEY=$_pf_key bash -lc $_pf_cq" </dev/null 2>/dev/null \
        | tr -d '\r' | grep -E '^(local-ok|local-down|cloud-ok|fallback)$' | tail -n1
}

cmd_opencode() {
    # --fresh (PENDING #20): wipe opencode session storage + logs before launch,
    # preserving auth. Must precede any `--`.
    _ensure_up
    fresh=0
    case "${1:-}" in --fresh) fresh=1; shift ;; esac
    if [ "$#" -gt 0 ] && [ "$1" = "--" ]; then shift; else set --; fi
    qargs=$(_shquote "$@")          # see cmd_claude — quote `-- <args>` as data

    # Refuse to silently use opencode's hosted default ("Big Pickle"/Zen): if no
    # usable local/cloud model is configured, warn loudly and require confirmation.
    case "$(_opencode_preflight)" in
        local-ok|cloud-ok) : ;;     # usable model — proceed
        local-down|fallback)
            printf '\033[1;31m\n'
            printf '  ⚠  NO LOCAL MODEL REACHABLE\n'
            printf '  opencode will use its hosted DEFAULT model (currently "Big Pickle" /\n'
            printf '  opencode Zen). Prompts and engagement data WILL leave this machine to a\n'
            printf '  third party and may be retained or used for training.\n'
            printf '\033[0m'
            printf '  -> Run `./pt-ai local-model detect` to point opencode at a local model.\n'
            if [ "${PT_AI_OPENCODE_ALLOW_FALLBACK:-0}" = 1 ]; then
                echo "[pt-ai] PT_AI_OPENCODE_ALLOW_FALLBACK=1 set — continuing without prompt." >&2
            elif [ -t 0 ]; then
                printf 'Continue with the hosted default model? [y/N] '
                read -r _pf_ans || _pf_ans=""
                case "$_pf_ans" in y|Y|yes|YES) ;; *) echo "Aborted."; return 1 ;; esac
            else
                echo "[pt-ai] Aborting: no TTY to confirm. Set PT_AI_OPENCODE_ALLOW_FALLBACK=1 to override." >&2
                return 1
            fi
            ;;
        *) echo "[pt-ai] model preflight inconclusive (VM unreachable?); proceeding." >&2 ;;
    esac

    wipe=''
    [ "$fresh" -eq 1 ] && wipe='echo "[pt-ai] --fresh: clearing opencode session storage (auth preserved)"; rm -rf ~/.local/share/opencode/storage ~/.local/share/opencode/log ~/.local/share/opencode/project; '

    # Model override is read at opencode startup; export inline. _shquote emits a
    # leading space, stripped here so it reads `OPENCODE_MODEL=<quoted>`.
    model_prefix=""
    if [ -n "${PT_AI_OPENCODE_MODEL:-}" ]; then
        mq=$(_shquote "$PT_AI_OPENCODE_MODEL")
        model_prefix="OPENCODE_MODEL=${mq# } "
    fi

    if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
        # Same short-lived temp-file trick as cmd_claude — key via SSH stdin.
        printf '%s' "$ANTHROPIC_API_KEY" | \
            _vagrant ssh -- -T "umask 077; cat > /tmp/.ptai-key"
        key='export ANTHROPIC_API_KEY=$(cat /tmp/.ptai-key) && rm -f /tmp/.ptai-key && '
    else
        key=''
    fi

    # _shquote the whole script for the outer (login-shell) layer; qargs is
    # already quoted for the inner `bash -c`.  See cmd_claude for the rationale.
    script="cd /engagements && ${wipe}${key}${model_prefix}opencode$qargs"

    # shellcheck disable=SC2029
    _vagrant ssh -- -t "bash -l -c $(_shquote "$script")"
}

# Best-effort: stop a running ghidra-rpc daemon so a live JVM/socket is not
# captured in (snapshot) or left stale across (restore) a VM image. Never fails
# the snapshot/restore — the daemon auto-restarts from the saved project on the
# next command anyway.
_ghidra_stop() {
    _vagrant ssh -- -T \
        '. /etc/profile.d/pt-ai-ghidra-rpc.sh 2>/dev/null || true; command -v ghidra-rpc >/dev/null 2>&1 && ghidra-rpc stop >/dev/null 2>&1; true' \
        >/dev/null 2>&1 || true
}

cmd_key() {
    _ensure_up            # store/clear/status all SSH into the VM — boot it first
    action="${1:-}"
    case "$action" in
        store)
            if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
                echo "pt-ai key store: ANTHROPIC_API_KEY is not set in the host environment" >&2
                exit 1
            fi
            # Stream the key over SSH stdin (never in argv); the guest wraps it
            # as a sourceable `export` line and umask 077 makes it 0600.
            printf '%s' "$ANTHROPIC_API_KEY" | _vagrant ssh -- -T \
                'umask 077; { printf "export ANTHROPIC_API_KEY="; cat; printf "\n"; } > ~/.anthropic_key'
            echo "API key stored in VM (~/.anthropic_key)."
            echo "All subsequent './pt-ai claude' sessions will use it."
            echo "Run './pt-ai key clear' to remove it."
            ;;
        clear)
            _vagrant ssh -- "rm -f ~/.anthropic_key"
            echo "API key removed from VM. Sessions will fall back to OAuth."
            ;;
        status)
            if _vagrant ssh -- "test -f ~/.anthropic_key" 2>/dev/null; then
                echo "API key: stored in VM (./pt-ai key clear to remove)"
            else
                echo "API key: not stored — using OAuth or per-session forwarding"
            fi
            ;;
        *)
            echo "Usage: pt-ai key <store|clear|status>" >&2
            exit 1
            ;;
    esac
}

cmd_snapshot() {
    case "${1:-}" in
        list|ls)
            _vagrant snapshot list      # read-only — no daemon quiesce needed
            return
            ;;
        "")
            echo "pt-ai snapshot: missing <name> (or 'list')" >&2; exit 1
            ;;
    esac
    _ghidra_stop            # quiesce the ghidra-rpc daemon before capturing state
    _vagrant snapshot save "$1"
}

cmd_restore() {
    if [ "$#" -lt 1 ]; then
        echo "pt-ai restore: missing <name>" >&2; exit 1
    fi
    _vagrant snapshot restore "$1"
    _ghidra_stop            # clear any stale daemon record from the restored image
}

cmd_halt()      { _vagrant halt; }
cmd_destroy()   { _vagrant destroy -f; }
cmd_provision() { _ensure_up; _vagrant provision; }   # `vagrant provision` needs the VM running
cmd_status()    { _vagrant status; }

# Host-side engagement data management. The engagements/ dir is a Vagrant
# synced_folder, so deleting here also clears it inside the VM, and works whether
# or not the VM is running. This operationalizes the framework's "ephemeral"
# principle by giving engagement data an explicit teardown path. NOTE: on an
# APFS/SSD host this is a logical delete (copy-on-write makes overwrite-erase
# ineffective) — FileVault is the real at-rest guarantee (see docs/data-at-rest.md).
cmd_engagement() {
    action="${1:-}"
    if [ "$#" -gt 0 ]; then shift; fi
    case "$action" in
        list|ls)
            if [ ! -d "$ENGAGEMENTS_DIR" ]; then echo "(no engagements dir yet)"; return 0; fi
            n=0
            for d in "$ENGAGEMENTS_DIR"/*/; do
                [ -d "$d" ] || continue
                n=$((n + 1))
                sz=$(du -sh "$d" 2>/dev/null | cut -f1)
                printf '  %-24s %s\n' "$(basename "$d")" "${sz:-?}"
            done
            [ "$n" = 0 ] && echo "  (none)"
            ;;
        purge|rm)
            force=0; target=""
            for a in "$@"; do
                case "$a" in
                    -y|--force) force=1 ;;
                    --all)      target="--all" ;;
                    -*)         echo "pt-ai engagement: unknown flag: $a" >&2; exit 1 ;;
                    *)          target="$a" ;;
                esac
            done
            [ -n "$target" ] || { echo "Usage: pt-ai engagement purge <id> | --all [-y]" >&2; exit 1; }

            if [ "$target" = "--all" ]; then
                if [ "$force" != 1 ]; then
                    printf 'Delete ALL engagement data under %s ? [y/N] ' "$ENGAGEMENTS_DIR"
                    read -r ans || ans=""
                    case "$ans" in y|Y|yes|YES) ;; *) echo "Aborted."; return 0 ;; esac
                fi
                # Wipe contents (incl. dotfiles like .DS_Store) but keep the synced
                # mount point itself so the next `up` doesn't need to recreate it.
                rm -rf "$ENGAGEMENTS_DIR"/* "$ENGAGEMENTS_DIR"/.[!.]* 2>/dev/null || true
                echo "All engagement data purged from $ENGAGEMENTS_DIR."
            else
                # Path-traversal guard: only a bare, safe id may be deleted.
                case "$target" in
                    */*|*..*|.) echo "pt-ai engagement: invalid id: '$target'" >&2; exit 1 ;;
                esac
                dir="$ENGAGEMENTS_DIR/$target"
                [ -d "$dir" ] || { echo "No such engagement: $target" >&2; exit 1; }
                if [ "$force" != 1 ]; then
                    printf 'Delete engagement %s (%s) ? [y/N] ' "$target" "$dir"
                    read -r ans || ans=""
                    case "$ans" in y|Y|yes|YES) ;; *) echo "Aborted."; return 0 ;; esac
                fi
                rm -rf "$dir"
                echo "Purged engagement: $target"
            fi
            echo "Note: APFS/SSD logical delete — FileVault is the at-rest guarantee (docs/data-at-rest.md)."
            ;;
        *)
            echo "Usage: pt-ai engagement <list|purge>" >&2
            echo "  list                 List engagements and their on-disk sizes" >&2
            echo "  purge <id> [-y]      Delete one engagement's data" >&2
            echo "  purge --all [-y]     Delete all engagement data" >&2
            exit 1
            ;;
    esac
}

if [ "$#" -lt 1 ]; then
    usage; exit 1
fi

sub="$1"; shift
case "$sub" in
    up)             cmd_up "$@" ;;
    ssh)            cmd_ssh "$@" ;;
    claude)         cmd_claude "$@" ;;
    opencode)       cmd_opencode "$@" ;;
    local-model)    cmd_local_model "$@" ;;
    key)            cmd_key "$@" ;;
    engagement)     cmd_engagement "$@" ;;
    snapshot)       cmd_snapshot "$@" ;;
    restore)        cmd_restore "$@" ;;
    halt)           cmd_halt ;;
    destroy)        cmd_destroy ;;
    provision)      cmd_provision ;;
    status)         cmd_status ;;
    -h|--help|help) usage ;;
    *)
        echo "pt-ai: unknown command: $sub" >&2
        usage; exit 1
        ;;
esac
